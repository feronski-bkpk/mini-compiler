digraph IR {
  rankdir=TB;
  node [shape=box, fontname="Courier"];

  subgraph cluster_factorial {
    label = "Function: factorial";
    style = filled;
    color = lightgrey;

    "L4" [label="L4\l", shape=box];
    "L3" [label="L3\lt2 = SUB n, 1\lPARAM 0, t2\lt3 = CALL factorial, t2\lt4 = MUL n, t3\lRETURN t4\l", shape=box];
    "L1" [label="L1\lt1 = CMP_LE n, 1\lJUMP_IF_NOT t1, L2\lJUMP L3\l", shape=box];
    "L2" [label="L2\lRETURN 1\l", shape=box];

    "L1" -> "L2";
    "L1" -> "L3";
  }

  subgraph cluster_main {
    label = "Function: main";
    style = filled;
    color = lightgrey;

    "L1" [label="L1\l", shape=box];
    "L2" [label="L2\lPARAM 0, 5\lt1 = CALL factorial, 5\lRETURN t1\l", shape=box];

  }

}
