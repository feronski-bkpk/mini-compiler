digraph IR {
  rankdir=TB;
  node [shape=box, fontname="Courier"];

  subgraph cluster_main {
    label = "Function: main";
    style = filled;
    color = lightgrey;

    "L2" [label="L2\ly = MOVE 10\lJUMP L4\l", shape=box];
    "L3" [label="L3\ly = MOVE 20\lJUMP L4\l", shape=box];
    "L1" [label="L1\lt1 = CMP_GT x, 0\lJUMP_IF_NOT t1, L2\lJUMP L3\l", shape=box];
    "L4" [label="L4\lRETURN y\l", shape=box];

    "L2" -> "L4";
    "L3" -> "L4";
    "L1" -> "L2";
    "L1" -> "L3";
  }

}
