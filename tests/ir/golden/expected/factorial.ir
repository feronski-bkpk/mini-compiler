function main: int ()
  L1:

  L2:
    PARAM 0, 5
    t1 = CALL factorial, 5
    RETURN t1


function factorial: int (int n)
  L1:
    t1 = CMP_LE n, 1
    JUMP_IF_NOT t1, L2
    JUMP L3

  L2:
    RETURN 1

  L3:
    t2 = SUB n, 1
    PARAM 0, t2
    t3 = CALL factorial, t2
    t4 = MUL n, t3
    RETURN t4

  L4:


